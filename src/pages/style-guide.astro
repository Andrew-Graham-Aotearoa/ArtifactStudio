---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Style Guide | Internal">


  <section class="max-w-3xl mx-auto px-6 py-16 space-y-10">

<div>
  <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-3">Brand Colours</p>
  <div class="flex gap-4">
    <div class="space-y-1">
      <div class="w-24 h-24 rounded border border-stone-200 bg-brand-bg"></div>
      <p class="text-xs font-body text-stone-500">Background</p>
      <code class="text-xs text-stone-400">#f1f8fd</code>
    </div>
    <div class="space-y-1">
      <div class="w-24 h-24 rounded bg-brand-accent"></div>
      <p class="text-xs font-body text-stone-500">Accent</p>
      <code class="text-xs text-stone-400">#2c3082</code>
    </div>
  </div>
</div>


    <div>
      <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-1">Hero / H1</p>
      <h1 class="text-5xl font-header font-black tracking-tight">Custom picture framing.</h1>
      <code class="text-xs text-stone-400">text-5xl font-header font-black tracking-tight</code>
    </div>

    <div>
      <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-1">Section / H2</p>
      <h2 class="text-3xl font-header font-bold">Our framing process</h2>
      <code class="text-xs text-stone-400">text-3xl font-header font-bold</code>
    </div>

    <div>
      <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-1">Subsection / H3</p>
      <h3 class="text-xl font-header font-semibold">Conservation framing</h3>
      <code class="text-xs text-stone-400">text-xl font-header font-semibold</code>
    </div>

    <div>
      <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-1">Lead paragraph</p>
      <p class="text-lg font-body leading-relaxed">
        We've been framing precious things for over a decade, treating every
        piece with the same care we'd want for our own.
      </p>
      <code class="text-xs text-stone-400">text-lg font-body leading-relaxed</code>
    </div>

    <div>
      <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-1">Body text</p>
      <p class="text-base font-body leading-relaxed">
        This is standard body copy as it would read across most pages —
        services descriptions, about page content, contact details.
      </p>
      <code class="text-xs text-stone-400">text-base font-body leading-relaxed</code>
    </div>

    <div>
      <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-1">Caption / meta</p>
      <p class="text-sm font-body text-stone-500">Est. 2014 — Cambridge, NZ</p>
      <code class="text-xs text-stone-400">text-sm font-body text-stone-500</code>
    </div>

    <div>
      <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-1">Nav / UI label</p>
      <p class="text-sm font-header font-medium">Framing Calculator</p>
      <code class="text-xs text-stone-400">text-sm font-header font-medium</code>
    </div>

    <div>
      <p class="text-sm font-header font-medium text-stone-400 uppercase tracking-wide mb-1">Button</p>
      <button class="font-header font-semibold tracking-wide bg-stone-900 text-white rounded px-5 py-2.5">
        Get a quote
      </button>
      <p class="mt-1"><code class="text-xs text-stone-400">font-header font-semibold tracking-wide</code></p>
    </div>

  
  </section>
</Layout>