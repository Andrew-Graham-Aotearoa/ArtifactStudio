---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact | Artifact Studio">
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h1 class="text-5xl font-header font-black leading-relaxed">Contact.</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-10 mt-10">
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-header font-bold">Visit</h2>
          <p class="mt-2 text-stone-500 font-body leading-relaxed">
            51 Seddon Street<br />
            Waihi 3610, New Zealand
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-header font-bold">Get in Touch</h2>
          <p class="mt-2 text-stone-500 font-body leading-relaxed">
            Phone / WhatsApp:
            <a href="tel:0272233561" class="text-brand-accent hover:underline">027 223 3561</a>
            <br />
            Email:
            <a href="artifactstudio.nz" class="text-brand-accent hover:underline">
              artifactstudio.nz
            </a>
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-header font-bold">Opening Hours</h2>
          <ul class="mt-2 text-stone-500 font-body leading-relaxed space-y-1">
            <li>Monday: 10am–4pm</li>
            <li>Tuesday: 10am–4pm</li>
            <li>Wednesday: 10am–4pm</li>
            <li>Thursday: 10am–12pm</li>
            <li>Friday: Matariki - Closed</li>
            <li>Saturday: 10am–2pm</li>
            <li>Sunday: Closed</li>
          </ul>
        </div>
      </div>

      <div class="w-full h-80 md:h-full min-h-[320px]">
        <iframe
          class="w-full h-full border-0 rounded-lg"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=51+Seddon+Street,+Waihi,+New+Zealand&output=embed"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>