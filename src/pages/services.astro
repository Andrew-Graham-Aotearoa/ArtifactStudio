---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Services | Artifact Studio.">
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h1 class="text-5xl font-header font-black leading-relaxed">Services.</h1>
    <section>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8">
        <div>
          <h2 class="mt-10 text-3xl font-header font-bold">
            Custom Picture Framing
          </h2>
          <ul class="mt-2 text-stone-500 font-body leading-relaxed space-y-1">
            <li>Custom Frame Design</li>
            <li>Glass Replacement</li>
            <li>Frame Cleaning</li>
            <li>Canvas Stretching</li>
            <li>Cross Stitch and Tapestry</li>
            <li>Float and Tray Frames</li>
            <li>Sports Jerseys</li>
          </ul>
        </div>
        <div>
          <h2 class="mt-10 text-3xl font-header font-bold">Design &amp; Digital</h2>
          <ul class="mt-2 text-stone-500 font-body leading-relaxed space-y-1">
            <li>Document Layout</li>
            <li>Photography</li>
            <li>Photo Restoration</li>
            <li>Logo and Branding Development</li>
            <li>Website Design and Development</li>
            <li>User Experience &amp; Interface Design</li>
          </ul>
          <p class="text-sm text-stone-500 font-body italic pt-2">
            Bespoke digital projects — get in touch to discuss scope and
            pricing.
          </p>
        </div>
      </div>
    </section>
  </section></Layout
>
