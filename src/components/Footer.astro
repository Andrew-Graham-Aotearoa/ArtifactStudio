---
const year = new Date().getFullYear();
---

<footer class="border-t border-brand-accent/20 mt-16">
  <div class="max-w-5xl mx-auto px-6 py-8 grid grid-cols-3 items-center gap-4">
    <p class="text-sm font-body text-stone-500 text-left">51 Seddon Street | Waihi | 3610 </p>
    <p class="text-sm font-body text-stone-500 text-center">&copy; {year} Artifact Studio.</p>
    <div class="flex items-center justify-end gap-4">

      <a href="https://www.instagram.com/artifactphotoandframe/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-stone-400 hover:text-brand-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r=".5" fill="currentColor" stroke="none"/>
        </svg>
      </a>

      <a href="https://www.facebook.com/profile.php?id=100085633746216" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-stone-400 hover:text-brand-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>

    </div>
  </div>
</footer>