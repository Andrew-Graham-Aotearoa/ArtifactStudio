---
// src/components/Nav.astro
const navLinks = [
  { label: 'Home',       href: '/'         },
  { label: 'Services',   href: '/services' },
  { label: 'About',      href: '/about'    },
  { label: 'Contact',    href: '/contact'  },
  // { label: 'Calculator', href: '/calculator' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-brand-bg border-b border-brand-accent/10">
  <div class="max-w-5xl mx-auto px-6 flex flex-wrap justify-between items-center py-4">

    <!-- Logo mark + business name -->
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.svg" alt="Artifact Studio logo mark" class="h-10 w-auto object-contain" />
      <div>
        <span class="block font-body text-lg leading-tight text-stone-900">Artifact Studio</span>
        <span class="block font-header font-medium text-xs text-stone-500 tracking-wide">Custom Picture Framing | Waihi NZ</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:block">
      <ul class="flex gap-8 text-sm tracking-wide">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`font-body transition-colors hover:text-brand-accent pb-0.5 ${
                currentPath === link.href
                  ? 'text-brand-accent border-b border-brand-accent'
                  : 'text-stone-900'
              }`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Hamburger button — mobile only -->
    <button
      id="menuBtn"
      type="button"
      class="md:hidden text-stone-900 hover:text-brand-accent transition-colors"
      aria-expanded="false"
      aria-controls="mobileMenu"
      aria-label="Toggle navigation menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Mobile menu -->
    <ul
      id="mobileMenu"
      class="hidden flex-col gap-3 mt-4 md:hidden bg-brand-bg w-full basis-full items-end border-t border-brand-accent/10 pt-4"
    >
      {navLinks.map(link => (
        <li class="w-full text-right">
          <a
            href={link.href}
            class={`font-body text-sm block py-1 transition-colors hover:text-brand-accent ${
              currentPath === link.href
                ? 'text-brand-accent'
                : 'text-stone-900'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('menuBtn') as HTMLButtonElement;
    const menu = document.getElementById('mobileMenu') as HTMLElement;

    function openMenu() {
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      btn.setAttribute('aria-expanded', 'true');
    }

    function closeMenu() {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      btn.setAttribute('aria-expanded', 'false');
    }

    function isMenuOpen() {
      return !menu.classList.contains('hidden');
    }

    btn.addEventListener('click', (e: MouseEvent) => {
      e.stopPropagation();
      isMenuOpen() ? closeMenu() : openMenu();
    });

    document.addEventListener('click', (e: MouseEvent) => {
      const target = e.target as Node;
      if (isMenuOpen() && !menu.contains(target) && !btn.contains(target)) {
        closeMenu();
      }
    });

    const observer = new ResizeObserver(() => {
      if (window.innerWidth >= 768 && isMenuOpen()) {
        closeMenu();
      }
    });
    observer.observe(document.body);
  });
</script>